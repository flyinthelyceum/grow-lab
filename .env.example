# GROWLAB environment — copy to `.env` and fill in.
# Read by systemd EnvironmentFile or whatever process supervisor you use.
# Env vars override values in config.toml [security].

# Hex sha256 of the admin password (NOT the password itself).
# Generate with:
#   python -c "import hashlib,getpass; print(hashlib.sha256(getpass.getpass('pw: ').encode()).hexdigest())"
GROWLAB_ADMIN_PASSWORD_SHA256=

# Random 32+ char string used to sign session cookies.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate to invalidate all existing sessions.
GROWLAB_SESSION_SECRET_KEY=
